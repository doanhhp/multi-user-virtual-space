# This .gitignore file is configured for Unity projects.
# It excludes build artifacts, IDE generated files, and large binary caches.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# PlasticSCM metadata
.plastic/

# Visual Studio / VS Code / Rider files
.vs/
.vscode/
.idea/
*.csproj
*.csproj.lscache
*.lscache
*.sln
*.slnx
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
crashlytics-build.properties

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Builds and packages
*.apk
*.aab
*.app
*.unitypackage

# Crash reports
CrashReport*/

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa.meta
/[Aa]ssets/[Ss]treaming[Aa]ssets/*/aa/*
~UnityDirMonSyncFile~*
